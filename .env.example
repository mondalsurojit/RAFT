# ---------------------------------------------------------------------------
# RAFT website environment variables. Copy this file to `.env` and fill in.
# Only VITE_*-prefixed vars are exposed to the client (and baked in at build).
# ---------------------------------------------------------------------------

# Contact form → Google Apps Script Web App "/exec" URL.
# Empty  → the form opens the visitor's mail client (mailto fallback).
# Set    → submissions are recorded to the Google Sheet and emailed to RAFT.
# See docs/contact-form-apps-script.md for how to deploy and get this URL.
VITE_CONTACT_FORM_ENDPOINT=

# OPTIONAL hardening — Google OAuth *Web* client ID (ends .apps.googleusercontent.com).
# Empty  → anyone can send (anonymous). Good for getting started / testing.
# Set    → "Sign in with Google" is REQUIRED before sending (strong anti-spam,
#          verified identity). Needs a Google Cloud OAuth client — see the doc.
VITE_GOOGLE_CLIENT_ID=
